# DeepSeek text models. These endpoints are expected to be OpenAI-compatible.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
NEO_AGENT_MAIN_MODEL=deepseek-v4-pro
NEO_AGENT_SMALL_MODEL=deepseek-v4-flash

# Xiaomi MiMo vision model. Also expected to be OpenAI-compatible.
MIMO_API_KEY=
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
NEO_AGENT_VISION_MODEL=mimo-v2.5

# Memory backend: local, openviking, or hybrid.
NEO_AGENT_MEMORY_BACKEND=hybrid
NEO_AGENT_OPENVIKING_URL=http://localhost:1933

# Agent data directory. Defaults to ~/.neo-agent.
NEO_AGENT_HOME=
