{
  "name": "neo-agent",
  "version": "0.1.0",
  "description": "Personal terminal AI agent with memory, skills, MCP, sub-agents, and multimodal routing.",
  "type": "module",
  "bin": {
    "neo-agent": "./dist/index.js",
    "neo": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "npm run build && node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
